# .env.example - API Keys & Secrets Template
# Copy to .env and fill in actual values (DO NOT COMMIT .env)
# .env is gitignored and will never be pushed to GitHub

# Google Chat Integration
# Get these from Google Cloud Console / service account JSON
GOOGLE_CHAT_BOT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/...
GOOGLE_CHAT_SPACE_ID=AAAAA...
GOOGLE_CHAT_API_KEY=your-api-key-here

# Ollama / Local Models (if needed)
OLLAMA_API_URL=http://localhost:11434

# Add more as needed
